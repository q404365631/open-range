{
  "id": "cyber.webapp.offense",
  "version": "cyber-webapp-offense-v2",
  "description": "Loopback-only vulnerable Python HTTP app used as source context for Builder-generated web offense tasks.",
  "runtime": {
    "kind": "python.http",
    "app": "app.py"
  },
  "deployment": {
    "kind": {
      "renderer": "kind/render_kind.py",
      "kind_config": "kind/kind-config.yaml",
      "topology": "kind/topology.json",
      "red_reference_plan": "kind/red-reference-plan.json"
    }
  },
  "families": {
    "code_web": [
      "sql_injection",
      "broken_authorization",
      "auth_bypass",
      "path_traversal",
      "ssrf",
      "command_injection"
    ],
    "config_identity": [
      "default_credential",
      "overbroad_service_account",
      "admin_surface_exposed"
    ],
    "secret_exposure": [
      "backup_leak",
      "credential_in_share",
      "hardcoded_app_secret"
    ],
    "telemetry_blindspot": [
      "request_log_review"
    ],
    "workflow_abuse": [
      "helpdesk_reset_bypass"
    ]
  },
  "attack_surface": {
    "discovery": [
      "/",
      "/robots.txt",
      "/openapi.json",
      "/.well-known/security.txt"
    ],
    "targets": [
      "/api/admin",
      "/search",
      "/records",
      "/download",
      "/fetch",
      "/ops",
      "/idp/token",
      "/vault",
      "/mailbox/support",
      "/siem/events"
    ]
  },
  "safety": {
    "network": "loopback-only",
    "shell": "simulated",
    "ssrf": "simulated-internal-map",
    "filesystem": "in-memory-fixtures"
  }
}
