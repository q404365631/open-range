{
  "id": "cyber.webapp.offense.kind",
  "description": "Kind-backed web offense range with enterprise-style zones, attacker and defender sandboxes, and intentionally vulnerable services.",
  "zones": [
    "external",
    "dmz",
    "corp",
    "data",
    "management"
  ],
  "services": [
    {
      "id": "sandbox-red",
      "kind": "sandbox",
      "role": "red",
      "zone": "external",
      "ports": []
    },
    {
      "id": "svc-web",
      "kind": "web_app",
      "zone": "dmz",
      "ports": [
        8080
      ],
      "exposure": "public"
    },
    {
      "id": "svc-email",
      "kind": "email",
      "zone": "corp",
      "ports": [
        8025
      ]
    },
    {
      "id": "svc-idp",
      "kind": "idp",
      "zone": "corp",
      "ports": [
        8080
      ]
    },
    {
      "id": "svc-fileshare",
      "kind": "fileshare",
      "zone": "data",
      "ports": [
        8080
      ]
    },
    {
      "id": "svc-db",
      "kind": "db",
      "zone": "data",
      "ports": [
        3306
      ]
    },
    {
      "id": "svc-siem",
      "kind": "siem",
      "zone": "management",
      "ports": [
        9200
      ]
    },
    {
      "id": "sandbox-blue",
      "kind": "sandbox",
      "role": "blue",
      "zone": "management",
      "ports": []
    }
  ],
  "weaknesses": [
    {
      "family": "code_web",
      "kind": "sql_injection",
      "target": "svc-web",
      "route": "/search"
    },
    {
      "family": "code_web",
      "kind": "broken_authorization",
      "target": "svc-web",
      "route": "/records"
    },
    {
      "family": "code_web",
      "kind": "auth_bypass",
      "target": "svc-web",
      "route": "/api/admin"
    },
    {
      "family": "code_web",
      "kind": "path_traversal",
      "target": "svc-web",
      "route": "/download"
    },
    {
      "family": "code_web",
      "kind": "ssrf",
      "target": "svc-web",
      "route": "/fetch"
    },
    {
      "family": "code_web",
      "kind": "command_injection",
      "target": "svc-web",
      "route": "/ops"
    },
    {
      "family": "config_identity",
      "kind": "default_credential",
      "target": "svc-idp",
      "route": "/idp/token"
    },
    {
      "family": "secret_exposure",
      "kind": "credential_in_share",
      "target": "svc-email",
      "route": "/mailbox/support"
    },
    {
      "family": "telemetry_blindspot",
      "kind": "request_log_review",
      "target": "svc-siem",
      "route": "/siem/events"
    }
  ],
  "reference_objectives": [
    "discover_surface",
    "gain_initial_access",
    "obtain_admin_secret",
    "review_siem_events"
  ]
}
